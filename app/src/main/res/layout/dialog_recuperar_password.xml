<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@color/login_surface"
    app:cardCornerRadius="28dp"
    app:cardElevation="24dp"
    app:strokeColor="@color/login_outline_variant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:id="@+id/containerRecuperar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:animateLayoutChanges="true">

        <TextView
            android:id="@+id/tvTituloRecuperar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recuperar Acceso"
            android:textColor="@color/login_on_surface"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvDescRecuperar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Introduce tu email para recibir un código de verificación."
            android:textColor="@color/login_on_surface_variant"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- Paso 1: Email -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CORREO ELECTRÓNICO"
            android:textColor="@color/login_on_surface_variant"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"
            android:paddingStart="4dp"/>
        <FrameLayout
            android:id="@+id/layoutEmailRecuperar"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="24dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="16dp"
                android:src="@android:drawable/ic_dialog_email"
                app:tint="@color/login_outline" />
            <EditText
                android:id="@+id/etEmailRecuperar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="estudiante@gmail.com"
                android:textColorHint="#80FFFFFF"
                android:textColor="@color/login_on_surface"
                android:textSize="14sp"
                android:paddingStart="48dp"
                android:paddingEnd="16dp"
                android:inputType="textEmailAddress" />
        </FrameLayout>

        <!-- Paso 2: Código (Oculto al inicio) -->
        <LinearLayout
            android:id="@+id/layoutCodigoVerificacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CÓDIGO DE VERIFICACIÓN"
                android:textColor="@color/login_on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:paddingStart="4dp"/>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="20dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="16dp"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="@color/login_outline" />
                <EditText
                    android:id="@+id/etCodigoRecuperar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="••••••"
                    android:textColorHint="#80FFFFFF"
                    android:textColor="@color/login_on_surface"
                    android:textSize="14sp"
                    android:paddingStart="48dp"
                    android:paddingEnd="16dp"
                    android:inputType="number"
                    android:maxLength="6" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NUEVA CONTRASEÑA"
                android:textColor="@color/login_on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:paddingStart="4dp"/>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="24dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="16dp"
                    android:src="@android:drawable/ic_lock_idle_lock"
                    app:tint="@color/login_outline" />
                <EditText
                    android:id="@+id/etNuevaPasswordRecuperar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="••••••••"
                    android:textColorHint="#80FFFFFF"
                    android:textColor="@color/login_on_surface"
                    android:textSize="14sp"
                    android:paddingStart="48dp"
                    android:paddingEnd="52dp"
                    android:inputType="textPassword" />

                <ImageView
                    android:id="@+id/ivTogglePasswordRecuperar"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_vertical|end"
                    android:padding="14dp"
                    android:src="@drawable/ic_visibility_off"
                    app:tint="@color/login_outline"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true" />
            </FrameLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnviarRecuperar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Enviar Código"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="20dp"
                app:backgroundTint="@color/login_primary" />

            <ProgressBar
                android:id="@+id/pbRecuperar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/white"/>
        </FrameLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>