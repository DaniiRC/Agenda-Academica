<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/login_bg">

    <!-- Ambient Glows -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-100dp"
        android:layout_marginTop="-100dp"
        android:alpha="0.1"
        android:background="@drawable/bg_glow_purple" />

    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-80dp"
        android:layout_marginBottom="-80dp"
        android:alpha="0.1"
        android:background="@drawable/bg_glow_yellow" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingVertical="40dp">

            <!-- Decorative layer -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-12dp"
                android:background="@drawable/bg_login_card_depth"
                app:layout_constraintTop_toTopOf="@id/loginCard"
                app:layout_constraintBottom_toBottomOf="@id/loginCard"
                app:layout_constraintStart_toStartOf="@id/loginCard"
                app:layout_constraintEnd_toEndOf="@id/loginCard" />

            <LinearLayout
                android:id="@+id/loginCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_login_card"
                android:padding="32dp"
                android:elevation="20dp"
                android:animateLayoutChanges="true"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_logo_bubble"
                    android:layout_marginBottom="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="A"
                        android:textColor="@color/login_primary"
                        android:textSize="28sp"
                        android:textStyle="normal" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvTitulo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bienvenido de nuevo"
                    android:textColor="@color/login_on_surface"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvSubtitulo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Continúa tu trayectoria académica."
                    android:textColor="@color/login_on_surface_variant"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="32dp"/>

                <!-- Nombre Input (Hidden by default) -->
                <LinearLayout
                    android:id="@+id/inputLayoutNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="NOMBRE COMPLETO"
                        android:textColor="@color/login_on_surface_variant"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp"
                        android:paddingStart="4dp"/>
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_input_field"
                        android:layout_marginBottom="20dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="16dp"
                            android:src="@android:drawable/ic_menu_edit"
                            app:tint="@color/login_outline" />
                        <EditText
                            android:id="@+id/etNombre"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:hint="Tu nombre"
                            android:textColorHint="@color/login_outline"
                            android:textColor="@color/login_on_surface"
                            android:textSize="14sp"
                            android:paddingStart="48dp"
                            android:paddingEnd="16dp"
                            android:inputType="textPersonName" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Email Input -->
                <LinearLayout
                    android:id="@+id/inputLayoutEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="CORREO ELECTRÓNICO"
                        android:textColor="@color/login_on_surface_variant"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp"
                        android:paddingStart="4dp"/>
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_input_field"
                        android:layout_marginBottom="20dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="16dp"
                            android:src="@android:drawable/ic_dialog_email"
                            app:tint="@color/login_outline" />
                        <EditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:hint="estudiante@gmail.com"
                            android:textColorHint="#80FFFFFF"
                            android:textColor="@color/login_on_surface"
                            android:textSize="14sp"
                            android:paddingStart="48dp"
                            android:paddingEnd="16dp"
                            android:inputType="textEmailAddress" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Password Input -->
                <LinearLayout
                    android:id="@+id/inputLayoutPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="CONTRASEÑA"
                        android:textColor="@color/login_on_surface_variant"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp"
                        android:paddingStart="4dp"/>
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_input_field">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="16dp"
                            android:src="@android:drawable/ic_lock_idle_lock"
                            app:tint="@color/login_outline" />

                        <EditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:paddingStart="48dp"
                            android:paddingEnd="52dp"
                            android:textColor="@color/login_on_surface"
                            android:textColorHint="#80FFFFFF"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/ivTogglePassword"
                            android:layout_width="48dp"
                            android:layout_height="match_parent"
                            android:layout_gravity="center_vertical|end"
                            android:padding="14dp"
                            android:src="@drawable/ic_visibility_off"
                            app:tint="@color/login_outline"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true" />
                    </FrameLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvOlvidePassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="¿Has olvidado tu contraseña?"
                    android:textColor="@color/login_outline"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAccion"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Iniciar Sesión"
                        android:textColor="@color/white"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="20dp"
                        app:backgroundTint="@color/login_primary"
                        app:icon="@android:drawable/ic_menu_send"
                        app:iconGravity="textEnd"
                        app:iconTint="@color/white" />

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="@color/white"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginTop="32dp">
                    <TextView
                        android:id="@+id/tvLabelNuevo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿Eres nuevo?"
                        android:textColor="@color/login_outline"
                        android:textSize="14sp"/>
                    <TextView
                        android:id="@+id/tvCambiarModo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Crea una cuenta"
                        android:textColor="@color/login_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</FrameLayout>
