<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardAsignatura"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeWidth="1dp"
    app:strokeColor="#0DFFFFFF"
    app:cardBackgroundColor="@color/bg_card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Indicador de color vertical -->
        <View
            android:id="@+id/viewColorLateral"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@drawable/gradient_blue_line"
            app:layout_constraintBottom_toBottomOf="@id/ivClaseImagen"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivClaseImagen" />

        <!-- Imagen de la clase -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivClaseImagen"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/viewColorLateral"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent" />

        <!-- Contenido -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivFlechaDerecha"
            app:layout_constraintStart_toEndOf="@id/ivClaseImagen"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvNombreAsignatura"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Nombre de la Clase"
                android:textColor="@color/text_main"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvInfoSecundaria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Código de clase"
                android:textColor="@color/text_sub"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_people"
                    app:tint="@color/text_hint" />

                <TextView
                    android:id="@+id/tvCountParticipantes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0 miembros"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp" />

                <View
                    android:id="@+id/dotSeparator"
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="@drawable/bg_dot"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvAdminTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_mayus"
                    android:textColor="@color/tag_admin_text"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/ivFlechaDerecha"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:alpha="0.3"
            android:src="@drawable/ic_chevron_right"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_main" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
